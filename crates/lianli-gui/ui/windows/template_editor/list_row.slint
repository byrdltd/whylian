import { Theme } from "../../theme.slint";
import { EditorWidget } from "types.slint";
import { ReorderButton } from "inputs.slint";

export component WidgetListRow inherits Rectangle {
    in property <EditorWidget> widget;
    in property <bool> selected;
    in property <int> index;
    in property <int> count;

    callback clicked(int);
    callback reorder(int, int);

    height: 28px;
    background: selected ? Theme.accent.transparentize(0.6) : transparent;
    border-radius: 3px;

    touch := TouchArea {
        clicked => { root.clicked(root.index); }
    }

    HorizontalLayout {
        padding-left: 8px;
        padding-right: 4px;
        spacing: 6px;
        Text {
            text: root.widget.kind-label;
            font-size: 11px;
            color: Theme.text-secondary;
            vertical-alignment: center;
            width: 78px;
        }
        Text {
            text: root.widget.id;
            font-size: 12px;
            color: Theme.text-primary;
            vertical-alignment: center;
            horizontal-stretch: 1;
        }
        VerticalLayout {
            alignment: center;
            spacing: 0px;
            ReorderButton {
                label: "▲";
                height: 12px;
                enabled: root.index > 0;
                clicked => { root.reorder(root.index, root.index - 1); }
            }
            ReorderButton {
                label: "▼";
                height: 12px;
                enabled: root.index < root.count - 1;
                clicked => { root.reorder(root.index, root.index + 1); }
            }
        }
    }
}
